
# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_use_a_strong_password
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_use_a_strong_password
S3_BUCKET_NAME=recipedb-media

# APNs (push notifications) — get these from Apple Developer portal
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.yourname.recipedb
APNS_KEY_PATH=/app/apns.p8
APNS_PRODUCTION=false
